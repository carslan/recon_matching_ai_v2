    },
    {
      "name": "sec_type_null_safe",
      "type": "STRING",
      "expression": "nullSafeString(sec_type)"
    },
    {
      "name": "orig_face_plus_fee_amt_factor_plus_1",
      "type": "DOUBLE",
      "expression": "nullSafePolynomial(orig_face,fee_amt,1)"
    },
    {
      "name": "orig_face_minus_collateral_factor_minus_1",
      "type": "DOUBLE",
      "expression": "nullSafePolynomial(orig_face,collateral,-1)"
    },
    {
      "name": "fail_face_coll",
      "type": "DOUBLE",
      "expression": "orig_face + collateral - fee_amt"
    },
    {
      "name": "orig_face_abs",
      "type": "DOUBLE",
      "expression": "nullSafeDoubleAbs(orig_face)"
    }
